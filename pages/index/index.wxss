.page {
  padding: 20rpx;
}

.overview-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.overview-header {
  margin-bottom: 30rpx;
}

.overview-date {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.overview-weekday {
  font-size: 24rpx;
  opacity: 0.8;
}

.overview-goal {
  text-align: right;
}

.goal-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.goal-value {
  font-size: 36rpx;
  font-weight: bold;
  margin: 0 8rpx;
}

.goal-unit {
  font-size: 24rpx;
  opacity: 0.8;
}

.calorie-ring {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin: 30rpx auto;
}

.ring-bg,
.ring-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-bg {
  background: rgba(255, 255, 255, 0.2);
}

.ring-progress {
  background: conic-gradient(
    transparent 0deg,
    transparent 90deg,
    rgba(255, 255, 255, 0.9) 90deg,
    rgba(255, 255, 255, 0.9) 360deg
  );
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%);
  transition: transform 0.5s ease;
}

.ring-progress.low {
  background: conic-gradient(
    transparent 0deg,
    transparent 90deg,
    #81d4fa 90deg,
    #81d4fa 360deg
  );
}

.ring-progress.good {
  background: conic-gradient(
    transparent 0deg,
    transparent 90deg,
    #a5d6a7 90deg,
    #a5d6a7 360deg
  );
}

.ring-progress.warning {
  background: conic-gradient(
    transparent 0deg,
    transparent 90deg,
    #ffcc80 90deg,
    #ffcc80 360deg
  );
}

.ring-progress.over,
.ring-progress.excess {
  background: conic-gradient(
    transparent 0deg,
    transparent 90deg,
    #ef9a9a 90deg,
    #ef9a9a 360deg
  );
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.current-cal {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1;
}

.ring-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 8rpx;
}

.nutrient-row {
  display: flex;
  justify-content: space-around;
  margin-top: 30rpx;
}

.nutrient-item {
  text-align: center;
  width: 30%;
}

.nutrient-progress {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 4rpx;
  margin-bottom: 12rpx;
  transition: width 0.3s ease;
}

.nutrient-value {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.nutrient-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

/* 热量状态提示 */
.calorie-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  margin-top: 20rpx;
}

.calorie-tip .tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.calorie-tip .tip-text {
  font-size: 26rpx;
  font-weight: 500;
}

.calorie-tip.low {
  background: rgba(129, 212, 250, 0.3);
  color: #fff;
}

.calorie-tip.good {
  background: rgba(165, 214, 167, 0.3);
  color: #fff;
}

.calorie-tip.warning {
  background: rgba(255, 204, 128, 0.3);
  color: #fff;
}

.calorie-tip.over,
.calorie-tip.excess {
  background: rgba(239, 154, 154, 0.3);
  color: #fff;
}

/* 餐次快捷添加 */
.meal-quick-add {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin: 20rpx 0;
}

.meal-quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.meal-quick-item:active {
  transform: scale(0.95);
}

.meal-quick-item .meal-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.meal-quick-item .meal-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.meal-quick-item .meal-cal {
  font-size: 20rpx;
  color: #999;
}

.meal-quick-item.active {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.meal-quick-item.active .meal-name,
.meal-quick-item.active .meal-cal {
  color: #fff;
}

.meal-badge {
  font-size: 28rpx;
  margin-right: 8rpx;
  opacity: 0.7;
}

.quick-add {
  margin: 30rpx 0;
}

.btn-add {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx dashed #07c160;
  border-radius: 50rpx;
  color: #07c160;
  font-size: 30rpx;
  padding: 24rpx;
}

.btn-add::after {
  border: none;
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.record-count {
  font-size: 24rpx;
  color: #999;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 30rpx;
  color: #333;
}

.record-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.record-delete {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 36rpx;
  color: #999;
  border-radius: 50%;
}

.record-delete:active {
  background: #f0f0f0;
}

.combine-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 1rpx solid #ffe066;
}

.combine-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.combine-content {
  flex: 1;
}

.combine-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.combine-desc {
  font-size: 24rpx;
  color: #996600;
  margin-top: 4rpx;
}

.combine-arrow {
  font-size: 48rpx;
  color: #cc9900;
}

.empty-state {
  padding: 60rpx 0;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  color: #999;
  font-size: 26rpx;
  line-height: 1.6;
}

/* 快捷功能入口 */
.quick-links {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.quick-link {
  flex: 1;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.3s;
}

.quick-link:active {
  transform: scale(0.95);
}

.quick-link.diet-link {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: #fff;
}

.quick-link.takeaway-link {
  background: linear-gradient(135deg, #ff6b35 0%, #f4511e 100%);
  color: #fff;
}

.quick-link.stats-link {
  background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%);
  color: #fff;
}

.link-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.link-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.link-desc {
  font-size: 22rpx;
  opacity: 0.85;
}
