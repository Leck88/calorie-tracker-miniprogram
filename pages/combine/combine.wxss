.page {
  padding: 20rpx;
}

.overview-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  position: relative;
}

.overview-header {
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.overview-content {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-value {
  font-size: 56rpx;
  font-weight: bold;
  line-height: 1;
  display: block;
}

.overview-unit {
  font-size: 24rpx;
  opacity: 0.8;
}

.overview-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 8rpx;
}

.overview-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 40rpx;
}

.status-tag {
  text-align: center;
  padding: 10rpx 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 24rpx;
  display: inline-block;
}

.status-tag.low {
  background: rgba(255, 193, 7, 0.3);
}

.status-tag.normal {
  background: rgba(255, 255, 255, 0.2);
}

.status-tag.over {
  background: rgba(255, 82, 82, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.nutrient-chart {
  display: flex;
  align-items: center;
}

.chart-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-right: 40rpx;
}

.ring-segment {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-segment.protein {
  background: conic-gradient(#4fc3f7 0deg, #4fc3f7 var(--p-angle, 0deg), transparent var(--p-angle, 0deg));
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%);
}

.ring-segment.carbs {
  background: conic-gradient(#ffb74d 0deg, #ffb74d var(--c-angle, 0deg), transparent var(--c-angle, 0deg));
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%);
}

.ring-segment.fat {
  background: conic-gradient(#e57373 0deg, #e57373 var(--f-angle, 0deg), transparent var(--f-angle, 0deg));
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%);
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.chart-legend {
  flex: 1;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.legend-dot.protein { background: #4fc3f7; }
.legend-dot.carbs { background: #ffb74d; }
.legend-dot.fat { background: #e57373; }

.legend-text {
  font-size: 28rpx;
  color: #666;
}

.recommend-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.recommend-item {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.recommend-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.recommend-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.recommend-cal {
  font-size: 26rpx;
  color: #07c160;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-protein {
  background: #e3f2fd;
  color: #1976d2;
}

.tag-light {
  background: #e8f5e9;
  color: #388e3c;
}

.tag-balance {
  background: #fff3e0;
  color: #f57c00;
}

.helper-card {
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 1rpx solid #ffe066;
}

.helper-tip {
  display: flex;
  align-items: flex-start;
}

.helper-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.helper-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.helper-desc {
  font-size: 26rpx;
  color: #996600;
  line-height: 1.6;
}

.quick-add-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.quick-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
}

.quick-name {
  font-size: 24rpx;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-cal {
  font-size: 22rpx;
  color: #07c160;
  margin-top: 4rpx;
}
