.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 概览卡片 */
.overview-card {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: #fff;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: bold;
}

.overview-goal {
  font-size: 24rpx;
  opacity: 0.8;
}

.overview-nums {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.num-item {
  text-align: center;
  padding: 0 40rpx;
}

.num-value {
  font-size: 60rpx;
  font-weight: bold;
  display: block;
  line-height: 1.2;
}

.num-value.over {
  color: #ff5252;
}

.num-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.num-divider {
  font-size: 48rpx;
  opacity: 0.3;
}

/* 提示 */
.tips {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
}

.tips.warning {
  background: rgba(255, 82, 82, 0.3);
}

.tips.small {
  background: #f5f5f5;
  margin-top: 16rpx;
}

.tips.small .tip-text {
  color: #999;
  font-size: 22rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  flex: 1;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999;
}

/* 食品网格 */
.food-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.food-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.3s;
}

.food-card:active {
  transform: scale(0.95);
  background: #e8f5e9;
}

.food-card.protein-card {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.food-emoji {
  font-size: 56rpx;
  display: block;
  margin-bottom: 8rpx;
}

.food-name {
  font-size: 24rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.food-tags {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  font-size: 18rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background: #07c160;
  color: #fff;
}

.tag.low-cal {
  background: #4caf50;
}

.tag.high-protein {
  background: #ff9800;
}

.tag.protein-tag {
  background: #e91e63;
}

.tag.fat-tag {
  background: #2196f3;
}

/* 减脂餐搭配 */
.meal-plans {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.meal-plan {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #4caf50;
}

.plan-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.plan-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.plan-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.plan-cal {
  font-size: 28rpx;
  font-weight: bold;
  color: #4caf50;
}

.plan-foods {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.plan-food {
  font-size: 22rpx;
  color: #666;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.plan-ratio {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.ratio-item {
  font-size: 22rpx;
  color: #999;
}

.btn-record {
  background: #4caf50;
  color: #fff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

.btn-record::after {
  border: none;
}

/* 负卡路里食物 */
.zero-cal-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.zero-cal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: #e8f5e9;
  border-radius: 12rpx;
}

.zero-cal-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.zero-cal-name {
  font-size: 22rpx;
  color: #2e7d32;
}

/* 底部固定按钮 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-quick-add {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-quick-add::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
