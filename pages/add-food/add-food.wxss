.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.mode-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 16rpx;
  color: #fff;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 30rpx;
  font-weight: bold;
}

/* 餐次选择 */
.meal-type-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.meal-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.meal-type-item.active {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-color: #07c160;
}

.meal-type-item .meal-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.meal-type-item .meal-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.meal-type-item .meal-time {
  font-size: 20rpx;
  color: #999;
}

.meal-type-item.active .meal-name,
.meal-type-item.active .meal-time {
  color: #fff;
}

.meal-type-item.active .meal-time {
  opacity: 0.8;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.search-wrap {
  margin-bottom: 20rpx;
}

.search-input {
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
}

.category-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.category-item.active {
  background: #07c160;
  color: #fff;
}

.food-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.food-option {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  background: #f8f8f8;
}

.food-option.selected {
  background: #e8f8ed;
  border: 2rpx solid #07c160;
}

.food-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.food-cal {
  font-size: 24rpx;
  color: #07c160;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 26rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.icon-picker {
  display: flex;
  flex-wrap: wrap;
}

.icon-option {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  background: #f5f5f5;
}

.icon-option.selected {
  background: #07c160;
}

.category-picker {
  display: flex;
  flex-wrap: wrap;
}

.category-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 40rpx;
  min-width: 100rpx;
}

.category-option.selected {
  background: #07c160;
}

.category-option.selected .cat-name {
  color: #fff;
}

.cat-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.weight-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.weight-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.weight-unit {
  font-size: 32rpx;
  color: #666;
}

.quick-weights {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.quick-weight {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.quick-weight.active {
  background: #07c160;
  color: #fff;
}

.calorie-preview {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #e8f8ed 0%, #d4f0e0 100%);
  border-radius: 16rpx;
}

.preview-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.preview-info {
  flex: 1;
}

.preview-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.preview-cal {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
}

.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-submit::after {
  border: none;
}
